# [UNTESTED] SP8192 + Headwise + GPTQ int6 (dim=448) — GPTQ control experiment
# Compare to Run 11 (1.2077, int8+zlib) — same config but with GPTQ int6 quantization
# GPTQ (Frantar et al., ICLR 2023) — ported from PG rank 9 (Marko Sisovic).
export MAX_WALLCLOCK_SECONDS=600
export RUN_ID=sp8192_combo_slim_gptq
export VAL_LOSS_EVERY=200
export TRAIN_LOG_EVERY=100
export GATED_ATTN=headwise
export ACTIVATION=leaky_relu2
export QK_GAIN_INIT=5.0
export VOCAB_SIZE=8192
export DATA_PATH=./data/datasets/fineweb10B_sp8192
export TOKENIZER_PATH=./data/tokenizers/fineweb_8192_bpe.model
export MODEL_DIM=448
export NUM_HEADS=8
export NUM_KV_HEADS=4
export NUM_LAYERS=9
export QUANT_MODE=int6_brotli
export SDCLIP_K=12.85
export EMBED_CLIP_K=20.0
export USE_GPTQ=1
export GPTQ_AR_SAMPLES=64
export GPTQ_AR_SEQLEN=2048
export GPTQ_TEMPERATURE=0.8
export GPTQ_BATCH_SIZE=8
export GPTQ_RESERVE_MS=30000
export TTT_MODE=score_first
export TTT_LR=0.005
export TTT_MOMENTUM=0.9
export TTT_EPOCHS=3
export TTT_CHUNK_TOKENS=32768
export TTT_FREEZE_BLOCKS=0
export TTT_GRAD_CLIP=1.0
export TTT_BATCH_SEQS=32
export SLM_ENABLED=0
export SLM_RATIO=0.6
