# N2: DiffAttn — N1 + Differential Attention (Paper #19, ICLR 2025 Oral)
# 2×H100, ~10 min wall clock
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/v2_base.env"
export RUN_ID=v2_n2_diffattn
# C6 config
export GATED_ATTN=headwise
export EMBED_BITS=7
export EMBED_CLIP_SIGMAS=15.0
# EMA + Small Batch
export EMA_DECAY=0.990
export GRAD_ACCUM_STEPS=1
export TRAIN_BATCH_TOKENS=196608
# Differential Attention ON
export DIFFATTN_ENABLED=1
export HYBRIDNORM_V=0
