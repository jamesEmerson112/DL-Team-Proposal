# S1: Cross-Sequence Attention — N1 base + eval-time KV cache across sequences
# 2×H100, ~10 min wall clock. Eval-only technique, no training change.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/v2_base.env"
export RUN_ID=v2_s1_crossseq
# C6 + EMA=0.990 + Small Batch (N1 base)
export GATED_ATTN=headwise
export EMBED_BITS=7
export EMBED_CLIP_SIGMAS=15.0
export EMA_DECAY=0.990
export GRAD_ACCUM_STEPS=1
export TRAIN_BATCH_TOKENS=196608
# Cross-Sequence Attention ON
export CROSS_SEQ_ATTN=1
export SCHEDULE_FREE=0
