# V3.1 Base — V2 with Week 1 retune
#
# Changes vs v2_base.env:
#   MIN_LR              0.0   -> 0.10      (warmdown LR floor, per rank 1)
#   WARMDOWN_FRAC       0.72  -> 0.85      (longer, gentler warmdown)
#   BETA2               0.95  -> 0.99      (AdamW, per rank 1)
#   EMBED_CLIP_SIGMAS   20.0  -> 14.0      (tighter int7 embed clip)
#   Per-group GPTQ clip sigmas (new knobs):
#     MLP_CLIP_SIGMAS   = 11.5             (rank 1 value)
#     ATTN_CLIP_SIGMAS  = 13.0             (rank 3/4 value)
#
# MATRIX_CLIP_SIGMAS is left in as a legacy fallback; v3.1's per-group path
# picks MLP/ATTN/EMBED based on tensor name.
#
# CaseOps plumbing is OFF by default. Enable via CASEOPS_ENABLED=1 once
# the caseops shards are prepped.

export MAX_WALLCLOCK_SECONDS=600
export RUN_ID=v3_1_base
export VAL_LOSS_EVERY=500
export TRAIN_LOG_EVERY=100
export VOCAB_SIZE=8192

# --- Architecture (unchanged from v2) ---
export NUM_LAYERS=11
export MODEL_DIM=512
export EMBEDDING_DIM=512
export NUM_HEADS=8
export NUM_KV_HEADS=4
export MLP_MULT=4
export TIE_EMBEDDINGS=1
export LOGIT_SOFTCAP=30

# --- Rank 1 techniques (unchanged from v2) ---
export QK_GAIN_INIT=5.25
export NUM_LOOPS=2
export LOOP_START=3
export LOOP_END=5
export ENABLE_LOOPING_AT=0.35
export PARALLEL_RESIDUAL_START=7
export SKIP_GATES_ENABLED=1
export ROPE_DIMS=16
export LN_SCALE=1
export XSA_LAST_N=11

# --- Optimizer (v3.1: WARMDOWN_FRAC, MIN_LR, BETA2 bumped) ---
export MUON_WD=0.095
export EMBED_WD=0.085
export ADAM_WD=0.02
export MATRIX_LR=0.022
export SCALAR_LR=0.02
export MUON_MOMENTUM=0.99
export MUON_ROW_NORMALIZE=1
export EMA_DECAY=0.9965
export WARMDOWN_FRAC=0.85      # [v3.1] was 0.72
export MIN_LR=0.10              # [v3.1] was 0.0
export BETA2=0.99               # [v3.1] was 0.95

# --- Quantization (v3.1: per-group clip sigmas + tighter embed clip) ---
export MATRIX_BITS=6
export EMBED_BITS=8
export MLP_CLIP_SIGMAS=11.5     # [v3.1] new, rank 1 value
export ATTN_CLIP_SIGMAS=13.0    # [v3.1] new, rank 3/4 value
export EMBED_CLIP_SIGMAS=14.0   # [v3.1] was 20.0
export MATRIX_CLIP_SIGMAS=12.85 # legacy fallback (unused when MLP/ATTN set)
export COMPRESSOR=brotli
export GPTQ_CALIBRATION_BATCHES=64
export GPTQ_RESERVE_SECONDS=12

# --- TTT (unchanged; phased LoRA TTT lands in v3.2) ---
export TTT_ENABLED=1
export TTT_LR=0.005
export TTT_EPOCHS=3
export TTT_MOMENTUM=0.9
export TTT_CHUNK_TOKENS=32768

# --- CaseOps plumbing (OFF until shards are prepped) ---
export CASEOPS_ENABLED=0

# --- Our novelty toggles (defaults = off) ---
export GATED_ATTN=none
export VALUE_RESIDUAL_ALPHA=0.0
