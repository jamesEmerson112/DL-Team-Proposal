# SLM smoke test — Selective Language Modeling (Rho-1, NeurIPS 2024)
# Keep top 60% tokens by loss, skip easy ones
# Compare against baseline Run 6v2 (1.2649 BPB, SP1024 GQA)
#
# Usage:
#   source runs/configs/slm_test.env && NGPUS=2 bash runs/parameter_golf_baseline.sh
export MAX_WALLCLOCK_SECONDS=600
export RUN_ID=slm_test_k60
export VAL_LOSS_EVERY=200
export TRAIN_LOG_EVERY=100
export GATED_ATTN=none
export ACTIVATION=relu2
export VOCAB_SIZE=1024
export TTT_MODE=none
export SLM_ENABLED=1
export SLM_RATIO=0.6
