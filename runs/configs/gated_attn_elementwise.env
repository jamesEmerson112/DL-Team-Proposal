# [Run 3] Gated Attention ablation — ELEMENTWISE variant (SP1024)
# BPB: 1.2602 | 19.42M params | 17.87 MB (OVER BUDGET) | Superseded by SP8192
# Paper: "Gated Attention for LLMs" (arxiv.org/abs/2505.06708, NeurIPS 2025 Best Paper)
# 1 sigmoid gate per dimension per head, doubles Q projection width (~2.4M extra params total)
#
# Usage:
#   source runs/configs/gated_attn_elementwise.env && bash runs/parameter_golf_baseline.sh
export MAX_WALLCLOCK_SECONDS=600
export RUN_ID=gated_attn_elementwise
export VAL_LOSS_EVERY=200
export TRAIN_LOG_EVERY=100
export GATED_ATTN=elementwise
export ACTIVATION=relu2
export VOCAB_SIZE=1024
export TTT_MODE=none
export SLM_ENABLED=0
export SLM_RATIO=0.6
export QUANT_MODE=int8_zlib
export USE_GPTQ=0
export GPTQ_CLIP_RANGE=63
export GPTQ_CALIB_SOURCE=ar
