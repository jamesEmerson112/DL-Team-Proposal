# Run 2: Legal baseline + Small Batch — C6 + EMA=0.990 + ga=1 (no PreQuantTTT)
# 8×H100, ~10 min wall clock
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/v2_base.env"
export RUN_ID=legal_ema090_smallbatch
# C6 config: headwise gate + emb7 + eclip15
export GATED_ATTN=headwise
export EMBED_BITS=7
export EMBED_CLIP_SIGMAS=15.0
# EMA tuning
export EMA_DECAY=0.990
# Small Batch (Paper #15): 4× more optimizer updates
export GRAD_ACCUM_STEPS=1
export TRAIN_BATCH_TOKENS=196608
# Legal: no PreQuantTTT
export PREQUANT_TTT_ENABLED=0
