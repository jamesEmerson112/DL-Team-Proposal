# Run 3: Best of Run 1/2 + PR #1855 clip sigmas (no PreQuantTTT)
# 8×H100, ~10 min wall clock
# NOTE: Update base config (GRAD_ACCUM_STEPS etc) based on Run 1 vs 2 winner
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/v2_base.env"
export RUN_ID=legal_ema090_clipsigma
# C6 config: headwise gate + emb7 + eclip15
export GATED_ATTN=headwise
export EMBED_BITS=7
export EMBED_CLIP_SIGMAS=14.0
# EMA tuning
export EMA_DECAY=0.990
# Small Batch — uncomment if Run 2 wins over Run 1
# export GRAD_ACCUM_STEPS=1
# export TRAIN_BATCH_TOKENS=196608
# PR #1855 GPTQ clip sigmas (codemath3000 greedy-validated)
export MLP_CLIP_SIGMAS=11.5
# EMBED_CLIP_SIGMAS already set to 14.0 above (from #1855's 14.0 vs our default 20.0)
# PreQuantTTT removed from codebase (C3 violation)
