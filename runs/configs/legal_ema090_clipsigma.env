# Run 3: C6 base (no EMA tuning, no Small Batch) + PR #1855 clip sigmas
# 8×H100, ~10 min wall clock
# Run 1 (EMA=0.990) and Run 2 (+Small Batch) both LOST to C6 baseline.
# So Run 3 tests clip sigmas on top of unmodified C6 config.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/v2_base.env"
export RUN_ID=legal_c6_clipsigma
# C6 config: headwise gate + emb7 (keep default EMA=0.9965, default batch)
export GATED_ATTN=headwise
export EMBED_BITS=7
# PR #1855 GPTQ clip sigmas (codemath3000 greedy-validated)
export MLP_CLIP_SIGMAS=11.5
export EMBED_CLIP_SIGMAS=14.0
# PreQuantTTT removed from codebase (C3 violation)
