# S2: Schedule-Free Optimizer — N1 base + schedule-free AdamW (Paper #23, NeurIPS 2024 Oral)
# 2×H100, ~10 min wall clock. Replaces AdamW for tok+scalar optimizers. Muon unchanged.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/v2_base.env"
export RUN_ID=v2_s2_schedulefree
# C6 + EMA=0.990 + Small Batch (N1 base)
export GATED_ATTN=headwise
export EMBED_BITS=7
export EMBED_CLIP_SIGMAS=15.0
export EMA_DECAY=0.990
export GRAD_ACCUM_STEPS=1
export TRAIN_BATCH_TOKENS=196608
# Schedule-Free ON
export CROSS_SEQ_ATTN=0
export SCHEDULE_FREE=1
