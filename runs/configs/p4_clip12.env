# P4 — P1a + tighter MATRIX_CLIP_SIGMAS to fit under 16 MB
# P1a was 16.35 MB (over budget) because MATRIX_CLIP_SIGMAS=11.5 allows larger weights.
# Tighten to 12.5 — should compress better under brotli while retaining most BPB gain.
#
# ⚠ MUST RUN ON CLEAN POD — no CaseOps symlinks!
# P1c (previous attempt) had 3 bugs: gate OFF + CaseOps byte inflation + CaseOps training data.
# All from pod symlinks pointing standard SP8192 paths to CaseOps data.
# Download standard data fresh: python data/cached_challenge_fineweb.py --vocab_size 8192
# Verify: token/byte ratio should be ~0.2683 (standard), NOT ~0.29 (CaseOps LUT) or ~0.32 (CaseOps sidecar).
export MAX_WALLCLOCK_SECONDS=600
export RUN_ID=p4_clip12
export VAL_LOSS_EVERY=500
export TRAIN_LOG_EVERY=100
export VOCAB_SIZE=8192
# Architecture (same as C6)
export NUM_LAYERS=11
export MODEL_DIM=512
export EMBEDDING_DIM=512
export NUM_HEADS=8
export NUM_KV_HEADS=4
export MLP_MULT=4
export TIE_EMBEDDINGS=1
export LOGIT_SOFTCAP=30
# Rank 1 techniques
export QK_GAIN_INIT=5.25
export NUM_LOOPS=2
export LOOP_START=3
export LOOP_END=5
export ENABLE_LOOPING_AT=0.35
export PARALLEL_RESIDUAL_START=7
export SKIP_GATES_ENABLED=1
export ROPE_DIMS=16
export LN_SCALE=1
export XSA_LAST_N=11
# Optimizer — SOTA overrides from P1a
export MUON_WD=0.095
export EMBED_WD=0.085
export ADAM_WD=0.02
export MATRIX_LR=0.022
export SCALAR_LR=0.02
export MUON_MOMENTUM=0.99
export MUON_ROW_NORMALIZE=1
export EMA_DECAY=0.9965
export BETA2=0.99                    # ★ SOTA (was 0.95)
export WARMDOWN_FRAC=0.85            # ★ SOTA (was 0.72)
export MIN_LR=0.10                   # ★ SOTA (was 0.0)
# Quantization — TIGHTENED clip to fit budget
export MATRIX_BITS=6
export EMBED_BITS=7                  # C6 setting
export MATRIX_CLIP_SIGMAS=12.5       # ★ TIGHTENED (P1a was 11.5, P1c was 12.0, C6 was 12.85)
export EMBED_CLIP_SIGMAS=14.0        # ★ SOTA (was 15.0, tighter embed)
export COMPRESSOR=brotli
export GPTQ_CALIBRATION_BATCHES=64
export GPTQ_RESERVE_SECONDS=0.5      # ★ SOTA (was 12, more training time)
# TTT (keep C6 SGD TTT)
export TTT_ENABLED=1
export TTT_LR=0.005
export TTT_EPOCHS=3
export TTT_MOMENTUM=0.9
export TTT_CHUNK_TOKENS=32768
# Our novelty
export GATED_ATTN=headwise
export GATED_ATTN_ENABLED=1            # PR #1851 style (boolean, not V2 string)
export VALUE_RESIDUAL_ALPHA=0.0
