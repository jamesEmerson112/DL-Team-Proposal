# [Run E1] SP8192 + ELEMENTWISE gated attention (dim=448)
# BPB: 1.2338 (2×H100) — BEST 2×H100 BPB EVER | 16.67 MB (OVER BUDGET by 0.67 MB)
# Beats Run A by -0.0073 but can't submit — needs int6/GPTQ to fit
export MAX_WALLCLOCK_SECONDS=600
export RUN_ID=sp8192_elem_dim448_2gpu
export VAL_LOSS_EVERY=200
export TRAIN_LOG_EVERY=100
export GATED_ATTN=elementwise
export ACTIVATION=leaky_relu2
export QK_GAIN_INIT=5.0
export VOCAB_SIZE=8192
export DATA_PATH=./data/datasets/fineweb10B_sp8192
export TOKENIZER_PATH=./data/tokenizers/fineweb_8192_bpe.model
export MODEL_DIM=448
export NUM_HEADS=8
export NUM_KV_HEADS=4
export NUM_LAYERS=9
export TTT_MODE=score_first
export TTT_LR=0.005
export TTT_MOMENTUM=0.9
export TTT_EPOCHS=3
export TTT_CHUNK_TOKENS=32768
export TTT_FREEZE_BLOCKS=0
export TTT_GRAD_CLIP=1.0
export TTT_BATCH_SEQS=32
export SLM_ENABLED=0
export SLM_RATIO=0.6
export QUANT_MODE=int8_zlib
export USE_GPTQ=0
export GPTQ_CLIP_RANGE=63
export GPTQ_CALIB_SOURCE=ar
export GPTQ_SEQUENTIAL=0
export GPTQ_USE_HOOKS=0
export GPTQ_EMBED=0
export GPTQ_PERCDAMP=0.01
