# P3 CORRECTED: PR #1851 base + our 3 novel contributions
# RETRACTED original P3 (1.0066 BPB) — inflated byte denominator from CASEOPS_ENABLED=0
# Corrected result: 1.0972 BPB (seed 42, 8xH100) — worse than C6 (1.0805)
#
# Fix: CASEOPS_ENABLED=1 + explicit DATA_PATH + sidecar byte counting
# See: docs/James_test/run_p3_rerun_correct_bytes.txt

SEED=42

# --- CaseOps tokenizer: ENABLED with explicit paths (no symlinks) ---
CASEOPS_ENABLED=1
DATA_PATH=./data/datasets/fineweb10B_sp8192_lossless_caps_caseops_v1_reserved
TOKENIZER_PATH=./data/tokenizers/fineweb_8192_bpe_lossless_caps_caseops_v1_reserved.model

# --- Novel contribution 1: Headwise Gated Attention ---
# Replaces sparse gate (PR #1851 default) with full headwise gate
# W_g: (num_heads, dim) = (8, 512) per layer, sigmoid gate on SDPA output
GATED_ATTN_ENABLED=1
SPARSE_ATTN_GATE_ENABLED=0

# --- Compression: reduce embedding quantization to fit under 16 MB ---
EMBED_BITS=6

# --- Novel contribution 2: EMA = 0.990 ---
# Our finding: 0.990 gives -0.012 BPB vs default 0.9965
EMA_DECAY=0.990

# --- Novel contribution 3: Small Batch ---
# ga=1 + reduced batch tokens = more update steps in fixed wall clock
# Our finding: -0.015 BPB on bigbag stack
GRAD_ACCUM_STEPS=1
TRAIN_BATCH_TOKENS=196608
