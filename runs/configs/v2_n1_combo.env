# N1: Legal combo baseline — C6 + EMA=0.990 + Small Batch
# 2×H100, ~10 min wall clock
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/v2_base.env"
export RUN_ID=v2_n1_combo
# C6 config: headwise gate + emb7 + eclip15
export GATED_ATTN=headwise
export EMBED_BITS=7
export EMBED_CLIP_SIGMAS=15.0
# EMA tuning (Session 16 finding: 0.990 optimal)
export EMA_DECAY=0.990
# Small Batch (Paper #15): 4× more optimizer updates on 2×H100
export GRAD_ACCUM_STEPS=1
export TRAIN_BATCH_TOKENS=196608
# Techniques off
export DIFFATTN_ENABLED=0
export HYBRIDNORM_V=0
