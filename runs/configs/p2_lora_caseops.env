# P2: LoRA TTT + CaseOps on P1a base (8×H100)
# Base: C6 + 6 SOTA hparam overrides from PR #1855

SEED=42

# Architecture (C6 base)
GATED_ATTN=headwise
SMEAR_GATE_ENABLED=0
VALUE_RESIDUAL_ALPHA=0.0
NUM_LOOPS=2

# SOTA hparam overrides (from P1a)
WARMDOWN_FRAC=0.85
MIN_LR=0.10
MATRIX_CLIP_SIGMAS=11.5
EMBED_CLIP_SIGMAS=14.0
BETA2=0.99
GPTQ_RESERVE_SECONDS=0.5

# Compression (C6 base)
EMBED_BITS=7

# SGD TTT disabled — LoRA TTT replaces it
TTT_ENABLED=0

# LoRA TTT
TTT_LORA_ENABLED=1
TTT_LORA_RANK=8
TTT_LORA_LR=0.01
TTT_LORA_CHUNK_SIZE=256
TTT_LORA_EVAL_SEQ_LEN=1024
TTT_LORA_BATCH_SIZE=64

# CaseOps tokenizer (uncomment after data prep)
# DATASETS_DIR=./data/datasets/fineweb10B_sp8192_caseops
# TOKENIZER_PATH=./data/tokenizers/fineweb_8192_bpe_lossless_caps_caseops_v1_reserved.model

# Standard
SLIDING_WINDOW_ENABLED=1
