# V3 overlay — HybridNorm (full recipe: V-norm + Post-Norm FFN)
# Source v1_base.env first, then this file to add HybridNorm on top of the baseline.
#
# HybridNorm (Kim et al., NeurIPS 2025, arXiv:2503.04598):
#   - V_NORM_ENABLED=1: RMSNorm on V projection inside attention
#     (Q and K already normed in rank 4).
#   - POST_NORM_FFN_ENABLED=1: replace FFN Pre-Norm with Post-Norm:
#     RMSNorm(x + scale * FFN(x)) instead of x + scale * FFN(Norm(x)).
#     Applied only to sequential layers (0..PARALLEL_START-1); parallel-residual
#     layers keep their existing structure — see train_v3.py comment at _parallel_block.
#
# Survey status: #21, not tested on the leaderboard yet.
# Use with train_v3.py.

export V_NORM_ENABLED=1
export POST_NORM_FFN_ENABLED=1
