# V2 overlay — Peri-LN
# Source v1_base.env first, then this file to add Peri-LN on top of the baseline.
#
# Peri-LN (Kim et al., ICML 2025, arXiv:2502.02732): RMSNorm on sublayer OUTPUT
# in addition to the existing Pre-LN on input. Stateless, zero new params.
# Survey status: #22, not tested on the leaderboard yet.
#
# Use with train_v2.py (NOT train_v1.py).

export PERI_LN_ENABLED=1
