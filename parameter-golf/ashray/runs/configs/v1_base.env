# V1 Base — Rank 4 (PR #1769, 1.0645 BPB) + MIN_LR=0.10 warmdown floor
# 11L × 512d × 8H/4KV, MLP 4×, LeakyReLU², CaseOps SP8192, GatedAttn, Loop4-5, Phased TTT.
# Diff vs rank 4: MIN_LR=0.10 (ported from PR #1787, rank 3, no code change).
# Any delta experiment should `source` this file first and then `export` only its
# specific overrides.

# Wallclock + logging
export MAX_WALLCLOCK_SECONDS=600
export VAL_LOSS_EVERY=0         # no periodic val during training; full TTT eval at the end
export TRAIN_LOG_EVERY=200

# Data (CaseOps SP8192)
export DATA_DIR=./data
export CASEOPS_ENABLED=1
export VOCAB_SIZE=8192

# Architecture (matches rank 4 defaults — listed here for clarity/overrideability)
export NUM_LAYERS=11
export MODEL_DIM=512
export NUM_HEADS=8
export NUM_KV_HEADS=4
export MLP_MULT=4
export TIE_EMBEDDINGS=1
export LOGIT_SOFTCAP=30
export ROPE_DIMS=16
export LN_SCALE=1
export QK_GAIN_INIT=5.0
export XSA_LAST_N=11

# Depth recurrence (Loop4-5 x2)
export NUM_LOOPS=2
export LOOP_START=4
export LOOP_END=5
export ENABLE_LOOPING_AT=0.35

# Parallel residuals from layer 8
export PARALLEL_RESIDUAL_START=8

# Gated attention (rank 4's distinguishing feature)
export GATED_ATTN_ENABLED=1
export GATED_ATTN_INIT_STD=0.005
export GATED_ATTN_QUANT_GATE=1

# Optimizer
export MATRIX_LR=0.026
# Warmdown floor: 10% of peak LR instead of decaying to 0. Validated by PR #1787
# (rank 3, 1.0634 BPB) as one of four additions on top of rank 4. No code change,
# no interactions — adopted as part of our base config.
export MIN_LR=0.10

# Quantization (int6 matrix + int7 embed)
export MATRIX_CLIP_SIGMAS=12.85
export ATTN_CLIP_SIGMAS=13.0
export MLP_CLIP_SIGMAS=12.0            # rank 4's key retune (was 10.0 in PR #1736)
export EMBED_BITS=7
export EMBED_CLIP_SIGMAS=15.0
export GPTQ_CALIBRATION_BATCHES=16
export GPTQ_RESERVE_SECONDS=4

# Phased TTT (score-first, per-doc LoRA reset)
export PHASED_TTT_ENABLED=1
export PHASED_TTT_PREFIX_DOCS=2000
export PHASED_TTT_NUM_PHASES=3

# NCCL transport hint for Runpod
export NCCL_NET=Socket
