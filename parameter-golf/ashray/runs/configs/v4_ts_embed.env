# V4 overlay — Universal-Transformer-style timestep embed for depth recurrence
# Source v1_base.env first, then this file.
#
# Adds a learned (num_loops+1, model_dim) tensor that gives the looped layers
# (LOOP_START..LOOP_END) a per-iteration signal so pass 1 can differ from pass 2.
# Defaults: Loop4-5 x2 means num_loops=2 -> 3 ts vectors -> 3 * 512 fp32 = ~6 KB.
# Zero-init so the model is bit-identical to v1 at step 0; training has to push
# it away from zero.
#
# Use with train_v4.py.

export TS_EMBED_ENABLED=1
